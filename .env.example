# ====================================
# Environment Configuration
# ====================================

# Application Environment
NODE_ENV=development

# Server Configuration
PORT=5000
HOST=localhost

# ====================================
# Database Configuration
# ====================================

# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-chatbot-uzair

# MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-chatbot-uzair?retryWrites=true&w=majority

# ====================================
# JWT Configuration
# ====================================

# JWT Secret Key (Change this in production!)
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production_12345
JWT_EXPIRE=7d

# ====================================
# Client Configuration
# ====================================

# Frontend URL
CLIENT_URL=http://localhost:3000

# API Base URL
API_BASE_URL=http://localhost:5000/api

# ====================================
# External APIs (Optional)
# ====================================

# OpenAI API (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# ====================================
# Development Settings
# ====================================

# Debug mode
DEBUG=true
LOG_LEVEL=info
